# Dependencies
node_modules/
*/node_modules/

# Environment variables — NEVER commit these
.env
backend/.env
frontend/.env

# Build output
frontend/build/
frontend/dist/

# Upload files (user-generated content)
backend/uploads/proofs/*
backend/uploads/charities/*
!backend/uploads/proofs/.gitkeep
!backend/uploads/charities/.gitkeep

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
